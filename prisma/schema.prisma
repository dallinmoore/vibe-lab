// Prisma schema — this is the heart of your data model.
//
// To change your data: edit the models below, then run `npm run db:migrate`
// (Claude can do this for you). That updates the database and regenerates the
// type-safe client your code uses.
//
// Engine: SQLite. The same file-based engine is used locally and in production
// (in prod the file lives on a Coolify persistent volume), so there's no
// "works locally, breaks in prod" surprises.
//
// SQLite note: it has no native enum or list/array column types. For a fixed
// set of values (e.g. a status), use a plain `String`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // Resolved from the DATABASE_URL env var. Locally: a file (file:./dev.db).
  // In production: a file on the mounted volume (e.g. file:/data/app.db).
  url      = env("DATABASE_URL")
}

/// A Jira-style issue on a shared team board.
///
/// The board is shared: every signed-in user sees and can edit all issues
/// (that's why there's no per-user scoping here — `creatorEmail` /
/// `assigneeEmail` track *who* rather than *gate access*).
///
/// `id` is an autoincrementing integer so we can render a human-readable key
/// like `VIBE-42`. SQLite only allows `autoincrement()` on the primary key,
/// so the id doubles as the issue number.
model Issue {
  id          Int    @id @default(autoincrement())
  title       String
  description String @default("")

  /// Kanban column. Plain String (SQLite has no enums): "todo" | "in_progress" | "done".
  status String @default("todo")

  /// Plain String (no enums): "low" | "medium" | "high" | "urgent".
  priority String @default("medium")

  /// Email of the assigned user, or null if unassigned. Any logged-in user.
  assigneeEmail String?

  /// Email of whoever created the issue.
  creatorEmail String

  /// Sort key within a column. Floats let us insert between two cards by
  /// averaging their positions, so a reorder only updates the moved card.
  position Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
